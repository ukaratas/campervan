# ESPHome secrets — kopyala: cp secrets.yaml.example secrets.yaml
# Daha sonra HAOS'taki /config/esphome/secrets.yaml ile birleştirilir.

# ── WiFi (tüm cihazlar için ortak) ────────────────────────────
wifi_ssid: "CAMPER-NEO"
wifi_password: "CHANGE_ME"

# ── cv-sensors-01 ─────────────────────────────────────────────
# `esphome wizard` çalıştırınca otomatik üretilen api/ota anahtarları.
# Yeni cihaz eklerken her biri için yeni anahtar üret.
cv_sensors_01_api_key: "CHANGE_ME_BASE64_KEY"
cv_sensors_01_ota_password: "CHANGE_ME_HEX_PASSWORD"
cv_sensors_01_ap_password: "CHANGE_ME_FALLBACK_AP_PWD"
