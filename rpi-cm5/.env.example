# LAN (caravan router). Remote: Tailscale URL (same token).
HA_URL=http://192.168.50.10:8123
HA_URL_REMOTE=http://100.x.x.x:8123
HA_TOKEN=your_long_lived_access_token_here

MQTT_HOST=192.168.50.10
MQTT_HOST_REMOTE=100.x.x.x
MQTT_PORT=1883
MQTT_USER=mqtt
MQTT_PASS=your_mqtt_password_here

# SSH artık key-based: önce `ssh-keygen -t ed25519 -f ~/.ssh/id_ed25519_haos` ile key üret,
# `~/.ssh/id_ed25519_haos.pub` içeriğini HA Terminal & SSH add-on'unda authorized_keys'e ekle,
# `~/.ssh/config`'e `Host haos-cv` bloğu yaz (User root, IdentityFile ~/.ssh/id_ed25519_haos).
# Geriye dönük uyumluluk için password ile bağlanmak istersen: SSH_PASS=...


RELAY_IP=192.168.50.20
RELAY_PORT=4196
