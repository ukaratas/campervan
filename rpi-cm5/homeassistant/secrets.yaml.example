# /config/secrets.yaml olarak kopyalayın; gerçek değerleri girin.
# Karavan HAOS (onboard RS485): rs485_serial_port satırını yeni cihaza göre güncelleyin.
# Slave ID'ler Modbus cihaz adresleriyle aynı — tek yerden yönetim için burada tutulur.

# USB–RS485 (CM5) veya onboard serial
rs485_serial_port: /dev/serial/by-id/usb-1a86_USB_Single_Serial_5A98053502-if00

# Waveshare Ethernet 16CH (RTU over TCP)
waveshare_ws01_host: 10.0.0.200
waveshare_ws01_port: 4196

# Slave ID’ler artık rs485_bus_devices/*.yaml içinde sabit (1 / 2 / 3).
# Eski kurulumda secrets.yaml’da kalan modbus_slave_* satırları zararsızdır (kullanılmıyor).
